# Copy to `.env.local` for local dev. Never commit real secrets.
# Canonical production: https://pokemon-indol-tau.vercel.app
# Retired domain (do not use): pokemon.ultharcr.com

# --- Site / routing ---
# NEXT_PUBLIC_SITE_URL=https://pokemon-indol-tau.vercel.app
# NEXT_PUBLIC_BASE_URL=https://your-domain.com
# Optional CDN prefix for static assets (assetPrefix)
# NEXT_PUBLIC_CDN_URL=
# Route PokeAPI through Next proxy + Upstash (recommended in production)
# NEXT_PUBLIC_POKEAPI_BASE_URL=/api/pokeapi
# RTDBBattleComponent Playwright mode only
# NEXT_PUBLIC_E2E=true

# --- Firebase client (required for auth / lobby / RTDB) ---
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_DATABASE_URL=

# --- Firebase Admin (server: battle create/submit) ---
# JSON string of the service account key
# FIREBASE_SERVICE_ACCOUNT_KEY=

# --- Upstash Redis (required in Vercel production for rate limits + proxy cache) ---
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Optional observability ---
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_ANALYTICS_URL=
