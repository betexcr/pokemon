# Optional: route Pokédex JSON through the Next.js proxy + Upstash Redis (shared cache).
# Leave unset locally to call PokeAPI directly from the browser.
# NEXT_PUBLIC_POKEAPI_BASE_URL=/api/pokeapi
# Server runtime: relative base is resolved with NEXT_PUBLIC_BASE_URL or VERCEL_URL (no trailing slash).
# NEXT_PUBLIC_BASE_URL=https://your-domain.com

# Required when using the proxy in production (server-side only).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
