// Firestore rules (rules_version = '2')

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function roomAffectedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function isRoomHost() {
      return resource.data.hostId == request.auth.uid;
    }

    function isRoomGuest() {
      return resource.data.guestId == request.auth.uid;
    }

    function hostImmutableRoomFieldsOk() {
      return request.resource.data.hostId == resource.data.hostId;
    }

    function hostForbiddenGuestKeys() {
      return !roomAffectedKeys().hasAny(['guestReady', 'guestTeam', 'guestId', 'guestName', 'guestPhotoURL']);
    }

    function guestFieldKeysOnly() {
      return roomAffectedKeys().hasOnly([
        'guestId', 'guestName', 'guestPhotoURL', 'guestTeam', 'guestReady',
        'guestReleasedTeam', 'guestAnimatingBalls', 'guestReleasedBalls',
        'activeUsers', 'currentPlayers', 'maxPlayers'
      ]);
    }

    function presenceKeysOnly() {
      return roomAffectedKeys().hasOnly(['activeUsers', 'currentPlayers', 'lastSeenHostAt']);
    }

    function battleIdUnchanged() {
      return (!('battleId' in resource.data) && !('battleId' in request.resource.data))
        || (('battleId' in resource.data)
          && ('battleId' in request.resource.data)
          && request.resource.data.battleId == resource.data.battleId);
    }

    function statusUnchanged() {
      return request.resource.data.status == resource.data.status;
    }

    function hostNotStartingBattle() {
      return request.resource.data.status != 'battling'
        && (!('battleId' in request.resource.data) || request.resource.data.battleId == null);
    }

    function teamsAndReadyLocked() {
      return !roomAffectedKeys().hasAny([
        'hostTeam', 'guestTeam', 'hostReady', 'guestReady'
      ]);
    }

    function noBattleIdOrNull() {
      return !('battleId' in resource.data) || resource.data.battleId == null;
    }

    match /battle_rooms/{roomId} {
      allow read: if isSignedIn() && (
        resource != null && resource.data.status in ['waiting', 'ready', 'battling', 'finished', 'unresolved'] ||
        resource == null ||
        (resource != null && (resource.data.hostId == request.auth.uid || resource.data.guestId == request.auth.uid))
      );

      allow create: if isSignedIn() &&
        request.resource.data.hostId == request.auth.uid
        && request.resource.data.status in ['waiting', 'ready']
        && (!('battleId' in request.resource.data) || request.resource.data.battleId == null)
        && !('hostTeam' in request.resource.data)
        && !('guestTeam' in request.resource.data);

      allow update: if isSignedIn() && hostImmutableRoomFieldsOk() && (
        (
          isRoomHost()
          && hostForbiddenGuestKeys()
          && (
            (
              resource.data.status in ['waiting', 'ready']
              && hostNotStartingBattle()
              && !roomAffectedKeys().hasAny(['hostTeam', 'guestTeam'])
            )
            ||
            (
              resource.data.status == 'battling'
              && battleIdUnchanged()
              && request.resource.data.status in ['battling', 'unresolved']
              && teamsAndReadyLocked()
            )
            ||
            (
              resource.data.status in ['finished', 'unresolved']
              && battleIdUnchanged()
              && statusUnchanged()
              && teamsAndReadyLocked()
            )
          )
        )
        ||
        (
          isRoomGuest()
          && guestFieldKeysOnly()
          && battleIdUnchanged()
          && statusUnchanged()
          && !roomAffectedKeys().hasAny(['guestTeam'])
        )
        ||
        (
          (!('guestId' in resource.data) || resource.data.guestId == null)
          && resource.data.status in ['waiting', 'ready']
          && noBattleIdOrNull()
          && request.resource.data.guestId == request.auth.uid
          && guestFieldKeysOnly()
          && !roomAffectedKeys().hasAny(['guestTeam'])
          && battleIdUnchanged()
          && request.resource.data.status in ['waiting', 'ready']
        )
        ||
        (
          presenceKeysOnly()
          && (isRoomHost() || isRoomGuest())
        )
      );

      allow delete: if isSignedIn() && resource.data.hostId == request.auth.uid;

      match /private/{docId} {
        allow read, write: if isSignedIn() && (
          get(/databases/$(database)/documents/battle_rooms/$(roomId)).data.hostId == request.auth.uid
          || get(/databases/$(database)/documents/battle_rooms/$(roomId)).data.guestId == request.auth.uid
        );
      }
    }

    match /battles/{battleId} {
      allow create: if false;
      allow read: if isSignedIn() && (
        resource.data.hostId == request.auth.uid ||
        resource.data.guestId == request.auth.uid
      );
      allow update, delete: if false;
    }

    match /user_teams/{uid}/{teamId} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    match /userTeams/{teamId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId;
    }

    match /users/{uid}/dex/{docId} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    function champAffectedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function isChampHost() {
      return resource.data.hostUid == request.auth.uid;
    }

    function champStatusUnchanged() {
      return request.resource.data.status == resource.data.status;
    }

    function champJoinAppendSelf() {
      return request.resource.data.participants.size() == resource.data.participants.size() + 1
        && request.resource.data.participants[request.resource.data.participants.size() - 1].uid == request.auth.uid;
    }

    match /championships/{champId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() &&
        request.resource.data.hostUid == request.auth.uid;

      allow update: if isSignedIn() && (
        (
          isChampHost()
          && request.resource.data.hostUid == resource.data.hostUid
        )
        ||
        (
          resource.data.status in ['open', 'seeding']
          && champStatusUnchanged()
          && request.resource.data.hostUid == resource.data.hostUid
          && request.resource.data.size == resource.data.size
          && champAffectedKeys().hasOnly(['participants', 'updatedAt'])
          && (
            champJoinAppendSelf()
            || request.resource.data.participants.size() == resource.data.participants.size() - 1
          )
        )
      );

      allow delete: if isSignedIn() && resource.data.hostUid == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
